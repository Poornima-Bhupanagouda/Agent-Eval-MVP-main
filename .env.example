# Lilly Agent Eval - Environment Configuration
# Copy this file to .env and fill in your values.
# Keep real secrets only in .env (already gitignored).

# ============================================
# LLM GATEWAY CONFIGURATION (PRIMARY FORMAT)
# ============================================
# These keys reflect the current .env format used in this project.
LLM_GATEWAY_KEY=your-llm-gateway-api-key
LLM_GATEWAY_BASE_URL=https://your-llm-gateway.example.com/llm-gateway
DEPLOYMENT_MODEL=gpt-4o-mini

# Aliases used by smart_rag_agent.py and test_llm_connection.py.
# Keep these aligned with the values above.
LLM_MODEL_API_KEY=your-llm-gateway-api-key
LLM_MODEL_BASE_URL=https://your-llm-gateway.example.com/llm-gateway
LLM_MODEL_NAME=gpt-4o-mini

# Optional generation settings
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4000

# ============================================
# OAUTH2 CONFIGURATION (FOR GATEWAY AUTH)
# ============================================
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_TENANT_ID=your-tenant-id
OAUTH_SCOPE=api://your-app-id/.default
# Optional explicit token URL
OAUTH_TOKEN_URL=https://login.microsoftonline.com/your-tenant-id/oauth2/v2.0/token

# ============================================
# RAG AGENT AUTHENTICATION
# ============================================
# Required by protected RAG endpoints (/chat, /describe)
RAG_AGENT_API_KEY=your-rag-agent-api-key

# ============================================
# MULTI-AGENT MODEL OVERRIDES (OPTIONAL)
# ============================================
# If unset, agents use LLM_MODEL_NAME.
# PLANNER_MODEL=gpt-4o-mini
# RESEARCHER_MODEL=gpt-4o
# SYNTHESIZER_MODEL=gpt-4o
# CRITIC_MODEL=gpt-4o

# ============================================
# AGENT NETWORK OVERRIDES (OPTIONAL)
# ============================================
# HOST=127.0.0.1
# PORT=8001
# ORCHESTRATOR_PORT=8010
# WEATHER_AGENT_PORT=8004
# WIKI_AGENT_PORT=8005
# WEATHER_AGENT_URL=http://127.0.0.1:8004/chat
# WIKI_AGENT_URL=http://127.0.0.1:8005/chat
# CALC_AGENT_URL=http://127.0.0.1:8006/chat

# ============================================
# ALTERNATIVE PROVIDERS (OPTIONAL)
# ============================================
# Use these if not using the gateway.
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=https://api.openai.com/v1
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_KEY=your-azure-openai-key

# ============================================
# EVALUATION STORAGE (OPTIONAL)
# ============================================
# LILLY_EVAL_DB=~/.agent_eval/data.db
