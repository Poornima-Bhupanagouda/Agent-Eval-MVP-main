#!/bin/bash
#
# Agent Eval - Startup Script
# Usage: ./start-eval [port] [--no-browser]
#
# This script:
#   1. Cleans up any existing processes on the target port
#   2. Clears Python cache files
#   3. Sets up the environment
#   4. Starts the FastAPI server
#   5. Opens the browser automatically
#

set -e

# Configuration
DEFAULT_PORT=8000
PORT="${1:-$DEFAULT_PORT}"
OPEN_BROWSER=true
HOST="0.0.0.0"
PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Parse arguments
for arg in "$@"; do
    case $arg in
        --no-browser)
            OPEN_BROWSER=false
            shift
            ;;
        --help|-h)
            echo "Usage: ./start-eval [port] [--no-browser]"
            echo ""
            echo "Options:"
            echo "  port          Port number (default: 8000)"
            echo "  --no-browser  Don't open browser automatically"
            echo "  --help, -h    Show this help message"
            exit 0
            ;;
        [0-9]*)
            PORT="$arg"
            ;;
    esac
done

# Banner
echo ""
echo -e "${CYAN}╔═══════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║${NC}          ${GREEN}🚀 Agent Eval - AI Testing Platform${NC}            ${CYAN}║${NC}"
echo -e "${CYAN}╚═══════════════════════════════════════════════════════════╝${NC}"
echo ""

# Step 1: Kill existing processes on the port
echo -e "${YELLOW}[1/5]${NC} Cleaning up port ${PORT}..."
cleanup_port() {
    local port=$1
    # Find and kill processes on the port
    if lsof -ti:$port > /dev/null 2>&1; then
        echo -e "  ${YELLOW}→${NC} Found existing process on port $port, terminating..."
        lsof -ti:$port | xargs kill -9 2>/dev/null || true
        sleep 1
        echo -e "  ${GREEN}✓${NC} Port $port cleared"
    else
        echo -e "  ${GREEN}✓${NC} Port $port is available"
    fi
}
cleanup_port $PORT

# Step 2: Clear Python cache
echo -e "${YELLOW}[2/5]${NC} Clearing Python cache..."
cd "$PROJECT_DIR"
find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
find . -type f -name "*.pyc" -delete 2>/dev/null || true
find . -type f -name "*.pyo" -delete 2>/dev/null || true
find . -type d -name ".pytest_cache" -exec rm -rf {} + 2>/dev/null || true
echo -e "  ${GREEN}✓${NC} Cache cleared"

# Step 3: Set up environment
echo -e "${YELLOW}[3/5]${NC} Setting up environment..."
export PYTHONPATH="${PROJECT_DIR}:${PYTHONPATH}"
export PYTHONDONTWRITEBYTECODE=1

# Check for .env file
if [ -f "$PROJECT_DIR/.env" ]; then
    echo -e "  ${GREEN}✓${NC} Found .env file"
    set -a
    source "$PROJECT_DIR/.env" 2>/dev/null || true
    set +a
else
    echo -e "  ${YELLOW}!${NC} No .env file found (optional)"
fi

# Check Python
if ! command -v python3 &> /dev/null; then
    echo -e "  ${RED}✗${NC} Python3 not found!"
    exit 1
fi
PYTHON_VERSION=$(python3 --version 2>&1)
echo -e "  ${GREEN}✓${NC} Using $PYTHON_VERSION"

# Step 4: Verify dependencies
echo -e "${YELLOW}[4/5]${NC} Checking dependencies..."
if python3 -c "import fastapi, uvicorn, pydantic" 2>/dev/null; then
    echo -e "  ${GREEN}✓${NC} Core dependencies available"
else
    echo -e "  ${YELLOW}!${NC} Installing dependencies..."
    pip install -q fastapi uvicorn pydantic httpx pyyaml 2>/dev/null || {
        echo -e "  ${RED}✗${NC} Failed to install dependencies"
        echo -e "  ${YELLOW}→${NC} Try: pip install -r requirements.txt"
        exit 1
    }
    echo -e "  ${GREEN}✓${NC} Dependencies installed"
fi

# Step 5: Start server
echo -e "${YELLOW}[5/5]${NC} Starting server..."
echo ""
echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo -e "  ${CYAN}Server:${NC}  http://localhost:${PORT}"
echo -e "  ${CYAN}API Docs:${NC} http://localhost:${PORT}/docs"
echo -e "  ${CYAN}Health:${NC}  http://localhost:${PORT}/health"
echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "  Press ${YELLOW}Ctrl+C${NC} to stop the server"
echo ""

# Open browser after short delay (in background)
if [ "$OPEN_BROWSER" = true ]; then
    (
        sleep 2
        if command -v open &> /dev/null; then
            open "http://localhost:${PORT}" 2>/dev/null
        elif command -v xdg-open &> /dev/null; then
            xdg-open "http://localhost:${PORT}" 2>/dev/null
        elif command -v start &> /dev/null; then
            start "http://localhost:${PORT}" 2>/dev/null
        fi
    ) &
fi

# Start uvicorn
cd "$PROJECT_DIR"
exec python3 -m uvicorn agent_eval.web.app:app \
    --host "$HOST" \
    --port "$PORT" \
    --reload \
    --reload-dir agent_eval
